NOME_TASK_AGENDADA = "ClaudeTI_RelatorioDiario"


def instalar_agendamento(horario: str, com_email: bool) -> None:
    """
    Registra este próprio script como uma Scheduled Task do Windows, rodando
    todo dia no horário informado. Usa 'schtasks /Create' — o mesmo comando
    que você já usa manualmente, só que automatizado aqui.
    """
    python_exe = sys.executable  # garante o mesmo interpretador/venv que está rodando agora
    script_path = os.path.abspath(__file__)
    flags = "--email" if com_email else ""
    comando = f'"{python_exe}" "{script_path}" {flags}'.strip()

    cmd = [
        "schtasks", "/Create",
        "/SC", "DAILY",
        "/TN", NOME_TASK_AGENDADA,
        "/TR", comando,
        "/ST", horario,
        "/F",  # sobrescreve se já existir uma task com esse nome
    ]

    print(f"Registrando task '{NOME_TASK_AGENDADA}' para rodar todo dia às {horario}...")
    resultado = subprocess.run(cmd, capture_output=True, text=True)
    if resultado.returncode != 0:
        raise RuntimeError(f"Falha ao criar a scheduled task: {resultado.stderr.strip()}")
    print("Task agendada com sucesso! Verifique no Agendador de Tarefas do Windows.")
    print(f"Comando registrado: {comando}")
    print("\nATENÇÃO: como o Agendador de Tarefas não herda variáveis de ambiente da sua sessão,")
    print("configure ANTHROPIC_API_KEY, SMTP_USER, SMTP_PASSWORD e EMAIL_DESTINATARIOS como")
    print("variáveis de ambiente do SISTEMA (não só da sessão do usuário), via:")
    print('  setx ANTHROPIC_API_KEY "sua_chave" /M')
    print("(repita para as demais, sempre com /M para o escopo de máquina)")


def desinstalar_agendamento() -> None:
    """Remove a scheduled task criada por este script."""
    cmd = ["schtasks", "/Delete", "/TN", NOME_TASK_AGENDADA, "/F"]
    resultado = subprocess.run(cmd, capture_output=True, text=True)
    if resultado.returncode != 0:
        raise RuntimeError(f"Falha ao remover a scheduled task: {resultado.stderr.strip()}")
    print(f"Task '{NOME_TASK_AGENDADA}' removida.")


