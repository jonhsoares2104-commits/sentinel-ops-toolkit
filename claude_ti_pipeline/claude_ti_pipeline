def montar_prompt(dados_atuais: dict, dados_anteriores: dict | None) -> str:
    """
    Instrui o modelo a devolver SOMENTE JSON, com um schema fixo.
    Isso facilita parsear a resposta sem se preocupar com texto solto.
    """
    comparacao_txt = (
        json.dumps(dados_anteriores, ensure_ascii=False)
        if dados_anteriores else "Nenhum snapshot anterior disponível (primeira execução)."
    )

    return f"""Você é um analista de infraestrutura de TI Windows. Analise os dados abaixo
e responda APENAS com um objeto JSON válido, sem markdown, sem texto antes ou depois,
seguindo exatamente este schema:

{{
  "resumo_executivo": "string curta, 3-4 frases, linguagem simples para gestão não-técnica",
  "nivel_geral": "OK" | "ATENCAO" | "CRITICO",
  "itens": [
    {{
      "categoria": "task" | "disco" | "servico",
      "nome": "string",
      "severidade": "OK" | "ATENCAO" | "CRITICO",
      "detalhe": "string curta explicando o problema (ou 'Normal' se estiver ok)",
      "recomendacao": "string curta com a próxima ação sugerida (ou 'Nenhuma ação necessária')"
    }}
  ],
  "mudancas_desde_ultima_execucao": [
    "string descrevendo cada mudança relevante (novo problema, problema resolvido, piora/melhora)"
  ]
}}

Regras de severidade (use exatamente estes critérios, não invente outros):
- Para cada disco, calcule o percentual livre como FreeGB / (UsedGB + FreeGB) * 100
- Disco com menos de {LIMITE_DISCO_CRITICO_PCT:.0f}% livre -> CRITICO
- Disco com menos de {LIMITE_DISCO_ATENCAO_PCT:.0f}% livre (mas acima do limite crítico) -> ATENCAO
- Task com LastTaskResult diferente de 0 -> ATENCAO; vira CRITICO se o nome da task contiver
  alguma destas palavras-chave (case-insensitive): {', '.join(PALAVRAS_CHAVE_TASK_CRITICA)}
- Serviço automático parado -> ATENCAO; vira CRITICO se o nome do serviço for um destes
  (case-insensitive): {', '.join(SERVICOS_CRITICOS)}

DADOS ATUAIS:
{json.dumps(dados_atuais, ensure_ascii=False)}

SNAPSHOT ANTERIOR (para comparação):
{comparacao_txt}
"""


def chamar_claude_api(prompt: str) -> dict:
    """
    Chama a API com retry + backoff exponencial simples.
    Valida se a resposta é um JSON parseável antes de devolver.
    """
    headers = {
        "x-api-key": API_KEY,
        "anthropic-version": "2023-06-01",
        "content-type": "application/json",
    }
    payload = {
        "model": MODEL,
        "max_tokens": 2000,
        "messages": [{"role": "user", "content": prompt}],
    }

    ultimo_erro = None
    for tentativa in range(1, MAX_RETRIES + 1):
        try:
            resp = requests.post(API_URL, headers=headers, json=payload, timeout=30)
            resp.raise_for_status()
            texto = resp.json()["content"][0]["text"]
            texto_limpo = texto.replace("```json", "").replace("```", "").strip()
            return json.loads(texto_limpo)
        except (requests.RequestException, KeyError, json.JSONDecodeError) as erro:
            ultimo_erro = erro
            print(f"[tentativa {tentativa}/{MAX_RETRIES}] falhou: {erro}")
            if tentativa < MAX_RETRIES:
                time.sleep(RETRY_BACKOFF_SECONDS * tentativa)

    raise RuntimeError(f"Não foi possível obter análise da API após {MAX_RETRIES} tentativas: {ultimo_erro}")


