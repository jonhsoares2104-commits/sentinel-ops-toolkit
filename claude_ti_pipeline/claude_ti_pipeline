COR_OK = colors.HexColor("#2e7d32")
COR_ATENCAO = colors.HexColor("#e65100")
COR_CRITICO = colors.HexColor("#c62828")
COR_HEADER = colors.HexColor("#1a237e")


def cor_severidade(sev: str):
    return {"OK": COR_OK, "ATENCAO": COR_ATENCAO, "CRITICO": COR_CRITICO}.get(sev, colors.black)


def gerar_pdf(dados_atuais: dict, analise: dict, caminho_saida: str) -> None:
    doc = SimpleDocTemplate(caminho_saida, pagesize=A4,
                             topMargin=2 * cm, bottomMargin=2 * cm)
    styles = getSampleStyleSheet()

    estilo_titulo = ParagraphStyle("TituloCustom", parent=styles["Title"], textColor=COR_HEADER)
    estilo_secao = ParagraphStyle("SecaoCustom", parent=styles["Heading2"], textColor=COR_HEADER, spaceBefore=14)
    estilo_normal = styles["Normal"]
    estilo_celula = ParagraphStyle("Celula", parent=styles["Normal"], fontSize=9, leading=11)

    story = []

    # --- Capa / cabeçalho ---
    story.append(Paragraph("Relatório de Saúde do Ambiente de TI", estilo_titulo))
    story.append(Paragraph(f"Gerado em {dados_atuais['coletado_em'].replace('T', ' ')}", estilo_normal))
    story.append(Spacer(1, 6))

    nivel = analise["nivel_geral"]
    story.append(Paragraph(
        f'Status geral: <font color="{cor_severidade(nivel).hexval()}"><b>{nivel}</b></font>',
        estilo_normal
    ))
    story.append(Spacer(1, 14))

    # --- Resumo executivo (gerado pelo Claude) ---
    story.append(Paragraph("Resumo Executivo", estilo_secao))
    story.append(Paragraph(analise["resumo_executivo"], estilo_normal))

    # --- Mudanças desde a última execução ---
    if analise.get("mudancas_desde_ultima_execucao"):
        story.append(Paragraph("Mudanças desde a última execução", estilo_secao))
        for mudanca in analise["mudancas_desde_ultima_execucao"]:
            story.append(Paragraph(f"• {mudanca}", estilo_normal))

    # --- Painel de severidade (tabela resumida) ---
    story.append(Paragraph("Painel de Itens Verificados", estilo_secao))
    cabecalho = ["Categoria", "Item", "Severidade", "Detalhe", "Recomendação"]
    linhas = [cabecalho]
    for item in analise["itens"]:
        linhas.append([
            item["categoria"].capitalize(),
            Paragraph(item["nome"], estilo_celula),
            Paragraph(f'<font color="{cor_severidade(item["severidade"]).hexval()}"><b>{item["severidade"]}</b></font>', estilo_celula),
            Paragraph(item["detalhe"], estilo_celula),
            Paragraph(item["recomendacao"], estilo_celula),
        ])

    tabela = Table(linhas, colWidths=[2.1 * cm, 3.3 * cm, 2.2 * cm, 5.2 * cm, 5.2 * cm], repeatRows=1)
    tabela.setStyle(TableStyle([
        ("BACKGROUND", (0, 0), (-1, 0), COR_HEADER),
        ("TEXTCOLOR", (0, 0), (-1, 0), colors.white),
        ("FONTSIZE", (0, 0), (-1, 0), 9),
        ("FONTNAME", (0, 0), (-1, 0), "Helvetica-Bold"),
        ("GRID", (0, 0), (-1, -1), 0.5, colors.grey),
        ("VALIGN", (0, 0), (-1, -1), "TOP"),
        ("ROWBACKGROUNDS", (0, 1), (-1, -1), [colors.white, colors.HexColor("#f5f5f5")]),
    ]))
    story.append(tabela)

    # --- Inventário bruto completo (segunda página) ---
    story.append(PageBreak())
    story.append(Paragraph("Anexo — Inventário Bruto Coletado", estilo_secao))

    story.append(Paragraph("Scheduled Tasks", styles["Heading3"]))
    linhas_tasks = [["Nome", "Última execução", "Código retorno", "Próxima execução"]]
    for t in dados_atuais["scheduled_tasks"]:
        linhas_tasks.append([
            Paragraph(t.get("TaskName", ""), estilo_celula),
            str(t.get("LastRunTime", "")),
            str(t.get("LastTaskResult", "")),
            str(t.get("NextRunTime", "")),
        ])
    tabela_tasks = Table(linhas_tasks, colWidths=[6 * cm, 4 * cm, 3 * cm, 4 * cm], repeatRows=1)
    tabela_tasks.setStyle(TableStyle([
        ("BACKGROUND", (0, 0), (-1, 0), colors.HexColor("#37474f")),
        ("TEXTCOLOR", (0, 0), (-1, 0), colors.white),
        ("GRID", (0, 0), (-1, -1), 0.5, colors.grey),
        ("FONTSIZE", (0, 0), (-1, -1), 9),
    ]))
    story.append(tabela_tasks)
    story.append(Spacer(1, 12))

    story.append(Paragraph("Discos", styles["Heading3"]))
    linhas_disco = [["Volume", "Usado (GB)", "Livre (GB)"]]
    for d in dados_atuais["discos"]:
        linhas_disco.append([d.get("Name", ""), str(d.get("UsedGB", "")), str(d.get("FreeGB", ""))])
    tabela_disco = Table(linhas_disco, colWidths=[4 * cm, 4 * cm, 4 * cm])
    tabela_disco.setStyle(TableStyle([
        ("BACKGROUND", (0, 0), (-1, 0), colors.HexColor("#37474f")),
        ("TEXTCOLOR", (0, 0), (-1, 0), colors.white),
        ("GRID", (0, 0), (-1, -1), 0.5, colors.grey),
        ("FONTSIZE", (0, 0), (-1, -1), 9),
    ]))
    story.append(tabela_disco)
    story.append(Spacer(1, 12))

    story.append(Paragraph("Serviços automáticos parados", styles["Heading3"]))
    if dados_atuais["servicos_parados"]:
        linhas_srv = [["Nome", "Status"]]
        for s in dados_atuais["servicos_parados"]:
            linhas_srv.append([s.get("Name", ""), s.get("Status", "")])
        tabela_srv = Table(linhas_srv, colWidths=[6 * cm, 6 * cm])
        tabela_srv.setStyle(TableStyle([
            ("BACKGROUND", (0, 0), (-1, 0), colors.HexColor("#37474f")),
            ("TEXTCOLOR", (0, 0), (-1, 0), colors.white),
            ("GRID", (0, 0), (-1, -1), 0.5, colors.grey),
            ("FONTSIZE", (0, 0), (-1, -1), 9),
        ]))
        story.append(tabela_srv)
    else:
        story.append(Paragraph("Nenhum serviço automático parado.", estilo_normal))

    doc.build(story)


