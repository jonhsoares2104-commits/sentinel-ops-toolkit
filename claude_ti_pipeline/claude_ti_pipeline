def main():
    parser = argparse.ArgumentParser(description="Pipeline de relatório de TI com análise via Claude API.")
    parser.add_argument("--demo", action="store_true", help="Roda com dados simulados, sem PowerShell nem API key.")
    parser.add_argument("--email", action="store_true", help="Envia o PDF por email após gerá-lo (requer variáveis SMTP_* e EMAIL_DESTINATARIOS).")
    parser.add_argument("--instalar-agendamento", action="store_true", help="Registra este script como Scheduled Task diária do Windows e encerra.")
    parser.add_argument("--desinstalar-agendamento", action="store_true", help="Remove a Scheduled Task criada anteriormente e encerra.")
    parser.add_argument("--horario", default="07:00", help="Horário diário da task (formato HH:MM, padrão 07:00). Usado com --instalar-agendamento.")
    args = parser.parse_args()

    if args.desinstalar_agendamento:
        desinstalar_agendamento()
        return

    if args.instalar_agendamento:
        instalar_agendamento(args.horario, com_email=args.email)
        return

    if args.demo:
        print("Rodando em modo demo (dados simulados)...")
        dados_atuais = dados_demo()
    else:
        if not API_KEY:
            sys.exit("ERRO: defina a variável de ambiente ANTHROPIC_API_KEY antes de rodar sem --demo.")
        print("Coletando dados via PowerShell...")
        dados_atuais = coletar_dados_sistema()

    dados_anteriores = carregar_snapshot_anterior()

    if args.demo:
        print("Gerando análise simulada...")
        analise = analise_demo(dados_atuais)
    else:
        print("Enviando dados para análise da Claude API...")
        prompt = montar_prompt(dados_atuais, dados_anteriores)
        analise = chamar_claude_api(prompt)

    print("Gerando PDF...")
    gerar_pdf(dados_atuais, analise, OUTPUT_PDF)

    if args.email:
        print("Enviando relatório por email...")
        enviar_email(OUTPUT_PDF, analise)

    salvar_snapshot(dados_atuais)
    print(f"Concluído! Relatório salvo em: {OUTPUT_PDF}")


if __name__ == "__main__":
    main()