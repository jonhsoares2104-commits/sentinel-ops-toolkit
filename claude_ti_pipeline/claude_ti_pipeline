def enviar_email(caminho_pdf: str, analise: dict) -> None:
    """
    Envia o PDF por email via SMTP (funciona com Office365, Gmail, servidor
    SMTP interno da empresa, etc — só trocar SMTP_HOST/PORT).
    Assunto muda conforme a severidade, pra facilitar priorização na caixa de entrada.
    """
    if not SMTP_USER or not SMTP_PASSWORD:
        print("AVISO: SMTP_USER/SMTP_PASSWORD não configurados — email não enviado.")
        return
    if not EMAIL_DESTINATARIOS:
        print("AVISO: EMAIL_DESTINATARIOS não configurado — email não enviado.")
        return

    nivel = analise.get("nivel_geral", "OK")
    prefixo = {"CRITICO": "[CRÍTICO] ", "ATENCAO": "[ATENÇÃO] ", "OK": ""}.get(nivel, "")
    data_str = datetime.now().strftime("%d/%m/%Y")

    msg = EmailMessage()
    msg["Subject"] = f"{prefixo}Relatório de Saúde de TI — {data_str}"
    msg["From"] = EMAIL_REMETENTE
    msg["To"] = ", ".join(EMAIL_DESTINATARIOS)
    msg.set_content(
        f"Olá,\n\nSegue em anexo o relatório automático de saúde do ambiente de TI.\n\n"
        f"Status geral: {nivel}\n\n"
        f"Resumo executivo:\n{analise.get('resumo_executivo', '')}\n\n"
        f"Relatório completo em anexo (PDF).\n\nEste é um email automático."
    )

    with open(caminho_pdf, "rb") as f:
        msg.add_attachment(
            f.read(), maintype="application", subtype="pdf",
            filename=os.path.basename(caminho_pdf)
        )

    ultimo_erro = None
    for tentativa in range(1, MAX_RETRIES + 1):
        try:
            with smtplib.SMTP(SMTP_HOST, SMTP_PORT, timeout=30) as servidor:
                servidor.starttls()
                servidor.login(SMTP_USER, SMTP_PASSWORD)
                servidor.send_message(msg)
            print(f"Email enviado para: {', '.join(EMAIL_DESTINATARIOS)}")
            return
        except smtplib.SMTPException as erro:
            ultimo_erro = erro
            print(f"[tentativa {tentativa}/{MAX_RETRIES}] falha ao enviar email: {erro}")
            if tentativa < MAX_RETRIES:
                time.sleep(RETRY_BACKOFF_SECONDS * tentativa)

    print(f"AVISO: não foi possível enviar o email após {MAX_RETRIES} tentativas: {ultimo_erro}")


